# ===========================================
# COGNISPACE Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in values
# DO NOT commit .env to version control
# ===========================================

# -----------------
# DATABASE (REQUIRED)
# -----------------
# MongoDB connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net
MONGO_URL=mongodb://localhost:27017

# Database name
DB_NAME=cognispace

# -----------------
# AUTHENTICATION (REQUIRED)
# -----------------
# JWT secret key - MUST change in production!
# Minimum 32 characters, random string
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars

# Super admin credentials - MUST change in production!
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=change-this-strong-password

# -----------------
# CORS (REQUIRED)
# -----------------
# Comma-separated list of allowed origins
# Use specific domains in production, not "*"
CORS_ORIGINS=http://localhost:3000

# -----------------
# AI FEATURES (Optional)
# -----------------
# Emergent LLM API key for TheraGenie & CogniVision
# Get from: Emergent Platform > Profile > Universal Key
EMERGENT_LLM_KEY=

# -----------------
# EMAIL NOTIFICATIONS (Optional)
# -----------------
# Resend API key
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender email (must be verified in Resend)
SENDER_EMAIL=

# -----------------
# WHATSAPP NOTIFICATIONS (Optional)
# -----------------
# Twilio credentials
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio WhatsApp number (format: +1234567890)
TWILIO_WHATSAPP_FROM=
