# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
dist/

# Environment files - KEEP for deployment
# .env
# .env.local
# .env.development.local
# .env.test.local
# .env.production.local
# Keep .env.example files
!.env.example
!**/.env.example

# Credentials (never commit)
*token.json*
*credentials.json*

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb
*.log

# System files
.DS_Store
*.pem
Thumbs.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
ENV/
env/
*.egg-info/
.eggs/
*.egg

# Package caches
.cache/
*.pack

# Misc
*.swp
*.swo
*~
frontend/node_modules/.cache/default-development/3.pack
frontend/node_modules/.cache/default-development/10.pack
frontend/node_modules/.cache/default-development/5.pack
frontend/node_modules/.cache/default-development/7.pack
frontend/node_modules/.cache/default-development/8.pack
frontend/node_modules/.cache/default-development/4.pack
